name: CI - Grid (Standalone per Browser)

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest

    strategy:
      fail-fast: false
      matrix:
        browser: [ chrome, firefox ]

    # Each job gets ONE selenium standalone container with the right browser
    services:
      selenium:
        image: selenium/standalone-${{ matrix.browser }}:4.18.1
        ports:
          - 4444:4444
        options: >-
          --shm-size="2g"
          --health-cmd="curl -fsS http://localhost:4444/status || exit 1"
          --health-interval=5s
          --health-timeout=2s
          --health-retries=25

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Temurin JDK 11
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '11'
          cache: maven

      - name: Print Java & Maven
        run: |
          java -version
          mvn -v

      - name: Generate testng-ci.xml (inject params)
        run: |
          cat > testng-ci.xml <<'EOF'
          <!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
          <suite name="Grid Suite" verbose="1" parallel="false">
            <parameter name="browser" value="${{ matrix.browser }}"/>
            <parameter name="gridUrl" value="http://localhost:4444"/>
            <test name="Grid Test">
              <classes>
                <class name="demo.GridLoginTest"/>
              </classes>
            </test>
          </suite>
          EOF
          echo "Generated testng-ci.xml:"
          cat testng-ci.xml

      - name: Wait for Selenium to be ready
        run: |
          for i in {1..40}; do
            if curl -fsS http://localhost:4444/status | grep -q '"ready":true'; then
              echo "Selenium is ready"; exit 0
            fi
            echo "Waiting for Selenium... ($i)"
            sleep 2
          done
          echo "Selenium did not become ready in time"; exit 1

      - name: Run tests on ${{ matrix.browser }}
        run: mvn -B -DsuiteFile=testng-ci.xml test

      - name: Upload Test Reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: reports-${{ matrix.browser }}
          path: |
            target/surefire-reports/**
            test-output/**
          if-no-files-found: warn
